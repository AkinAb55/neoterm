  <string name="pref_general_microphone">Microphone</string>
  <string name="pref_general_microphone_desc">Let apps in the Linux distro use the device microphone (PulseAudio source)</string>
  <string name="pref_general_camera">Camera</string>
  <string name="pref_general_camera_desc">Let apps in the Linux distro use the device camera as an MJPEG stream (NEOTERM_CAMERA_URL). Works with URL-aware apps (ffmpeg, OpenCV, mpv); not a /dev/video0 device.</string>
  <string name="pref_general_camera_resolution">Camera resolution</string>
  <string name="pref_general_camera_resolution_desc">Capture resolution for the camera stream. Lower means less latency and bandwidth; the closest size the camera supports is used.</string>
  <string name="pref_general_gps">GPS / Location</string>
  <string name="pref_general_gps_desc">Built-in gpsd: serves the device GPS to the Linux distro on 127.0.0.1:2947 (gpsd protocol). No gpsd needed — just run cgps / gpspipe / gpsmon.</string>
  <string name="pref_general_usb_serial">USB serial (/dev/ttyUSB)</string>
  <string name="pref_general_usb_serial_desc">Drive USB-serial adapters (FTDI, CP210x, CH34x, PL2303, CDC-ACM) app-side and expose them to the distro as /dev/ttyUSB*. No root. Device list comes from the Linux kernel driver IDs. Takes effect on the next plug-in.</string>
  <string name="pref_general_sensors">Sensors &amp; battery (/sys)</string>
  <string name="pref_general_sensors_desc">Expose the device battery and motion/environment sensors to the distro as a fake /sys/class/power_supply and /sys/bus/iio/devices tree. No root — upower, acpi, iio_info, cat and IIO-aware tools work. Takes effect on the next session.</string>
  <string-array name="pref_general_camera_resolution_entries" translatable="false">
    <item>320x240</item>
